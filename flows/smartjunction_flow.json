    "id": "text-j2-vehicles", "type": "ui_text", "group": "group-j2", "order": 1, "width": "3", "label": "Vehicles", "format": "🚗 {{msg.payload}}", "layout": "row-spread", "wires": []
  },
  {
    "id": "gauge-j2-traffic", "type": "ui_gauge", "group": "group-j2", "order": 2, "width": "3", "gtype": "gage", "title": "Traffic Score", "label": "%", "format": "{{value}}", "min": "0", "max": "100", "colors": ["#00b400","#e6e600","#ca3838"], "seg1": "40", "seg2": "70", "wires": []
  },
  {
    "id": "text-j2-signal", "type": "ui_text", "group": "group-j2", "order": 3, "width": "3", "label": "Signal", "format": "<b>{{msg.payload}}</b>", "layout": "row-spread", "wires": []
  },
  {
    "id": "text-j2-alert", "type": "ui_text", "group": "group-j2", "order": 4, "width": "3", "label": "Status", "format": "{{msg.payload}}", "layout": "row-spread", "wires": []
  },

  {
    "id": "mqtt-in-j3-sensors",
    "type": "mqtt in",
    "name": "J3 Sensors",
    "topic": "smartjunction/J3/sensors",
    "qos": "0",
    "datatype": "json",
    "broker": "broker-local",
    "wires": [["fn-j3-sensors"]]
  },
  {
    "id": "fn-j3-sensors",
    "type": "function",
    "name": "Parse J3 sensors",
    "func": "var p = msg.payload;\nreturn [\n  { payload: p.vehicles || 0 },\n  { payload: p.traffic_score || 0 },\n  { payload: p.signal || '?' },\n  { payload: p.ambulance ? '🚑 AMBULANCE' : (p.fire_truck ? '🚒 FIRE TRUCK' : (p.accident ? '💥 ACCIDENT' : '✅ Normal')) }\n];",
    "outputs": 4,
    "wires": [["text-j3-vehicles"], ["gauge-j3-traffic"], ["text-j3-signal"], ["text-j3-alert"]]
