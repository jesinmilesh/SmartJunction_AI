[
  {
    "id": "broker-local",
    "type": "mqtt-broker",
    "name": "Local MQTT (Mosquitto)",
    "broker": "localhost",
    "port": "1883",
    "clientid": "node-red-smartjunction",
    "autoConnect": true,
    "usetls": false,
    "protocolVersion": "4",
    "keepalive": "60",
    "cleansession": true
  },
  {
    "id": "tab-dashboard",
    "type": "ui_tab",
    "name": "SmartJunction AI",
    "icon": "traffic",
    "disabled": false,
    "hidden": false
  },
  {
    "id": "group-j1", "type": "ui_group", "name": "Junction J1", "tab": "tab-dashboard", "order": 1, "disp": true, "width": "6", "collapse": false
  },
  {
    "id": "group-j2", "type": "ui_group", "name": "Junction J2", "tab": "tab-dashboard", "order": 2, "disp": true, "width": "6", "collapse": false
  },
  {
    "id": "group-j3", "type": "ui_group", "name": "Junction J3", "tab": "tab-dashboard", "order": 3, "disp": true, "width": "6", "collapse": false
  },
  {
    "id": "group-j4", "type": "ui_group", "name": "Junction J4", "tab": "tab-dashboard", "order": 4, "disp": true, "width": "6", "collapse": false
  },
  {
    "id": "group-alerts", "type": "ui_group", "name": "Emergency Alerts", "tab": "tab-dashboard", "order": 5, "disp": true, "width": "12", "collapse": false
  },
  {
    "id": "group-controls", "type": "ui_group", "name": "Manual Override (All Junctions)", "tab": "tab-dashboard", "order": 6, "disp": true, "width": "12", "collapse": false
  },

  {
    "id": "mqtt-in-j1-sensors",
    "type": "mqtt in",
    "name": "J1 Sensors",
    "topic": "smartjunction/J1/sensors",
    "qos": "0",
    "datatype": "json",
    "broker": "broker-local",
    "wires": [["fn-j1-sensors"]]
  },
  {
    "id": "fn-j1-sensors",
    "type": "function",
    "name": "Parse J1 sensors",
    "func": "var p = msg.payload;\nreturn [\n  { payload: p.vehicles || 0 },\n  { payload: p.traffic_score || 0 },\n  { payload: p.signal || '?' },\n  { payload: p.ambulance ? '🚑 AMBULANCE' : (p.fire_truck ? '🚒 FIRE TRUCK' : (p.accident ? '💥 ACCIDENT' : '✅ Normal')) }\n];",
    "outputs": 4,
    "wires": [["text-j1-vehicles"], ["gauge-j1-traffic"], ["text-j1-signal"], ["text-j1-alert"]]
  },
  {
    "id": "text-j1-vehicles", "type": "ui_text", "group": "group-j1", "order": 1, "width": "3", "label": "Vehicles", "format": "🚗 {{msg.payload}}", "layout": "row-spread", "wires": []
  },
  {
    "id": "gauge-j1-traffic", "type": "ui_gauge", "group": "group-j1", "order": 2, "width": "3", "gtype": "gage", "title": "Traffic Score", "label": "%", "format": "{{value}}", "min": "0", "max": "100", "colors": ["#00b400","#e6e600","#ca3838"], "seg1": "40", "seg2": "70", "wires": []
  },
  {
    "id": "text-j1-signal", "type": "ui_text", "group": "group-j1", "order": 3, "width": "3", "label": "Signal", "format": "<b>{{msg.payload}}</b>", "layout": "row-spread", "wires": []
  },
  {
    "id": "text-j1-alert", "type": "ui_text", "group": "group-j1", "order": 4, "width": "3", "label": "Status", "format": "{{msg.payload}}", "layout": "row-spread", "wires": []
  },

  {
    "id": "mqtt-in-j2-sensors",
    "type": "mqtt in",
    "name": "J2 Sensors",
    "topic": "smartjunction/J2/sensors",
    "qos": "0",
    "datatype": "json",
