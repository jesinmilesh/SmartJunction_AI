    "id": "text-j3-vehicles", "type": "ui_text", "group": "group-j3", "order": 1, "width": "3", "label": "Vehicles", "format": "🚗 {{msg.payload}}", "layout": "row-spread", "wires": []
  },
  {
    "id": "gauge-j3-traffic", "type": "ui_gauge", "group": "group-j3", "order": 2, "width": "3", "gtype": "gage", "title": "Traffic Score", "label": "%", "format": "{{value}}", "min": "0", "max": "100", "colors": ["#00b400","#e6e600","#ca3838"], "seg1": "40", "seg2": "70", "wires": []
  },
  {
    "id": "text-j3-signal", "type": "ui_text", "group": "group-j3", "order": 3, "width": "3", "label": "Signal", "format": "<b>{{msg.payload}}</b>", "layout": "row-spread", "wires": []
  },
  {
    "id": "text-j3-alert", "type": "ui_text", "group": "group-j3", "order": 4, "width": "3", "label": "Status", "format": "{{msg.payload}}", "layout": "row-spread", "wires": []
  },

  {
    "id": "mqtt-in-j4-sensors",
    "type": "mqtt in",
    "name": "J4 Sensors",
    "topic": "smartjunction/J4/sensors",
    "qos": "0",
    "datatype": "json",
    "broker": "broker-local",
    "wires": [["fn-j4-sensors"]]
  },
  {
    "id": "fn-j4-sensors",
    "type": "function",
    "name": "Parse J4 sensors",
    "func": "var p = msg.payload;\nreturn [\n  { payload: p.vehicles || 0 },\n  { payload: p.traffic_score || 0 },\n  { payload: p.signal || '?' },\n  { payload: p.ambulance ? '🚑 AMBULANCE' : (p.fire_truck ? '🚒 FIRE TRUCK' : (p.accident ? '💥 ACCIDENT' : '✅ Normal')) }\n];",
    "outputs": 4,
    "wires": [["text-j4-vehicles"], ["gauge-j4-traffic"], ["text-j4-signal"], ["text-j4-alert"]]
  },
  {
    "id": "text-j4-vehicles", "type": "ui_text", "group": "group-j4", "order": 1, "width": "3", "label": "Vehicles", "format": "🚗 {{msg.payload}}", "layout": "row-spread", "wires": []
  },
  {
    "id": "gauge-j4-traffic", "type": "ui_gauge", "group": "group-j4", "order": 2, "width": "3", "gtype": "gage", "title": "Traffic Score", "label": "%", "format": "{{value}}", "min": "0", "max": "100", "colors": ["#00b400","#e6e600","#ca3838"], "seg1": "40", "seg2": "70", "wires": []
  },
  {
    "id": "text-j4-signal", "type": "ui_text", "group": "group-j4", "order": 3, "width": "3", "label": "Signal", "format": "<b>{{msg.payload}}</b>", "layout": "row-spread", "wires": []
  },
  {
    "id": "text-j4-alert", "type": "ui_text", "group": "group-j4", "order": 4, "width": "3", "label": "Status", "format": "{{msg.payload}}", "layout": "row-spread", "wires": []
