  {
    "id": "mqtt-in-emergency", "type": "mqtt in", "name": "Emergency Broadcast", "topic": "smartjunction/emergency", "qos": "1", "datatype": "json", "broker": "broker-local", "wires": [["fn-emergency"]]
  },
  {
    "id": "fn-emergency", "type": "function", "name": "Format Emergency", "func": "var p = msg.payload;\nif (p.type === 'CLEAR') {\n  msg.payload = '✅ Emergency CLEARED';\n} else {\n  var icon = p.type === 'AMBULANCE' ? '🚑' : '🚒';\n  msg.payload = icon + ' ' + p.type + ' at Junction ' + p.source + ' — All others RED!';\n}\nreturn msg;", "outputs": 1, "wires": [["text-emergency"]]
  },
  {
    "id": "text-emergency", "type": "ui_text", "group": "group-alerts", "order": 1, "width": "12", "label": "Emergency", "format": "<span style='font-size:1.2em;font-weight:bold'>{{msg.payload}}</span>", "layout": "row-spread", "wires": []
  },

  {
    "id": "btn-green-all", "type": "ui_button", "name": "Force GREEN all", "group": "group-controls", "order": 1, "width": "3", "label": "🟢 GREEN All", "bgcolor": "#1a7a1a", "wires": [["fn-green-all"]]
  },
  {
    "id": "fn-green-all", "type": "function", "name": "GREEN all junctions", "func": "var jcts = ['J1','J2','J3','J4'];\nreturn jcts.map(j => ({ topic:'smartjunction/'+j+'/cmd', payload:'GREEN' }));", "outputs": 4, "wires": [["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"]]
  },
  {
    "id": "btn-red-all", "type": "ui_button", "name": "Force RED all", "group": "group-controls", "order": 2, "width": "3", "label": "🔴 RED All", "bgcolor": "#7a1a1a", "wires": [["fn-red-all"]]
  },
  {
    "id": "fn-red-all", "type": "function", "name": "RED all junctions", "func": "var jcts = ['J1','J2','J3','J4'];\nreturn jcts.map(j => ({ topic:'smartjunction/'+j+'/cmd', payload:'RED' }));", "outputs": 4, "wires": [["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"]]
  },
  {
    "id": "btn-auto-all", "type": "ui_button", "name": "Auto all", "group": "group-controls", "order": 3, "width": "3", "label": "♻ AUTO All", "bgcolor": "#15527a", "wires": [["fn-auto-all"]]
  },
  {
    "id": "fn-auto-all", "type": "function", "name": "AUTO all junctions", "func": "var jcts = ['J1','J2','J3','J4'];\nreturn jcts.map(j => ({ topic:'smartjunction/'+j+'/cmd', payload:'AUTO' }));", "outputs": 4, "wires": [["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"], ["mqtt-cmd-out"]]
  },
  {
    "id": "btn-clear-emergency", "type": "ui_button", "name": "Clear Emergency", "group": "group-controls", "order": 4, "width": "3", "label": "✅ Clear Emergency", "bgcolor": "#b30000", "wires": [["fn-clear-emergency"]]
  },
  {
    "id": "fn-clear-emergency", "type": "function", "name": "Clear emergency", "func": "msg.topic = 'smartjunction/emergency';\nmsg.payload = JSON.stringify({ source:'NodeRED', type:'CLEAR' });\nreturn msg;", "outputs": 1, "wires": [["mqtt-cmd-out-raw"]]
  },
  {
    "id": "mqtt-cmd-out", "type": "mqtt out", "name": "MQTT Command OUT", "topic": "", "qos": "0", "broker": "broker-local", "wires": []
  },
  {
    "id": "mqtt-cmd-out-raw", "type": "mqtt out", "name": "MQTT Raw OUT", "topic": "", "qos": "1", "broker": "broker-local", "wires": []
  }
]
